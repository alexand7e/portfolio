# ─────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite .env, .env.local, .env.production ou docker.env.
# ─────────────────────────────────────────────────────────────

# Database (Neon / Postgres). String de conexão completa.
# Payload usa o schema "payload" (isolado do schema public do Prisma).
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require&pgbouncer=true&connect_timeout=15"

# Payload CMS
# Gere com: openssl rand -base64 32
PAYLOAD_SECRET="gere-com-openssl-rand-base64-32"

# Site
SITE_URL="http://localhost:7000"

# Gmail SMTP (para newsletter)
# Senha de app: Google Account → Segurança → Verificação em 2 etapas → Senhas de app
GMAIL_USER="seuemail@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# EmailJS (públicos por design — expostos ao browser)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""

# Google Analytics (opcional, público)
NEXT_PUBLIC_GA_ID=""

# Giscus (comentários no blog) — https://giscus.app
GISCUS_REPO_ID=""
GISCUS_REPO=""
GISCUS_CATEGORY_ID=""
GISCUS_CATEGORY=""